# ===========================================
# PhuongAnh-TTS Backend - Environment Configuration
# ===========================================

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
MONGODB_URI=mongodb://admin:phuonganh_secure_password_2024@localhost:27017/?authSource=admin
MONGODB_DB_NAME=phuonganh_tts

# ===========================================
# REDIS CONFIGURATION
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# JWT & SECURITY
# ===========================================
# IMPORTANT: Change this in production!
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production-2024
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Password hashing
PASSWORD_MIN_LENGTH=8
BCRYPT_ROUNDS=12

# ===========================================
# STORAGE CONFIGURATION
# ===========================================
AUDIO_STORAGE_PATH=./data/audios
TEMP_STORAGE_PATH=./data/temp
MAX_AUDIO_SIZE_MB=100
MAX_AUDIO_DURATION_SECONDS=600

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Free tier limits
FREE_DAILY_AUDIO_LIMIT=10
FREE_MONTHLY_CHARS_LIMIT=10000
FREE_MAX_TEXT_LENGTH=500
FREE_MAX_DURATION=30

# Plus tier limits
PLUS_DAILY_AUDIO_LIMIT=100
PLUS_MONTHLY_CHARS_LIMIT=100000
PLUS_MAX_TEXT_LENGTH=2000
PLUS_MAX_DURATION=120

# Pro tier limits
PRO_DAILY_AUDIO_LIMIT=-1  # unlimited
PRO_MONTHLY_CHARS_LIMIT=500000
PRO_MAX_TEXT_LENGTH=10000
PRO_MAX_DURATION=600

# ===========================================
# SERVER CONFIGURATION
# ===========================================
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=false
LOG_LEVEL=INFO

# ===========================================
# CORS CONFIGURATION
# ===========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:7860,http://127.0.0.1:3000,http://127.0.0.1:7860

# ===========================================
# ENVIRONMENT
# ===========================================
ENVIRONMENT=development
DEBUG=true
